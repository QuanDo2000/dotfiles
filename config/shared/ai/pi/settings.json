{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "medium",
  "defaultProjectTrust": "ask",
  "enableInstallTelemetry": false,
  "enableSkillCommands": true,
  "skills": [
    "~/.codex/skills"
  ],
  "packages": [
    "npm:pi-mcp-extension@1.5.0",
