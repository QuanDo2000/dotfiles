{
  "layer": "top",
  "position": "top",
  "output": "DP-3",
  "height": 35,
  "reload_style_on_change": true,
  "spacing": 0,

  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "privacy",
    "custom/input-method",
    "custom/hyprsunset",
    "mpris",
    "pulseaudio",
    "idle_inhibitor",
    "network",
    "custom/power"
  ],

  "hyprland/workspaces": {
    "format": "{icon} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "â€¢",
    "window-rewrite": {
      "class<com.mitchellh.ghostty>": "ï„ ",
      "class<google-chrome>": "ï‰¨",
      "class<thunar>": "ïپ»",
      "class<obsidian>": "َ° ®",
      "class<anki>": "َ°ک¸"
    },
    "on-click": "activate",
    "disable-scroll": true,
    "sort-by-number": true,
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": []
    },
    "format-icons": {
      "active": "â—ڈ",
      "urgent": "â—ڈ",
      "default": "â—‹"
    }
  },

  "hyprland/window": {
    "format": "{title}",
    "max-length": 60,
    "separate-outputs": true
  },

  "clock": {
    "interval": 60,
    "format": "{:%Y-%m-%d  %H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "right"
    }
  },

  "privacy": {
    "icon-spacing": 8,
    "icon-size": 18,
    "transition-duration": 0,
    "modules": [
      { "type": "screenshare" },
      { "type": "audio-in" }
    ]
  },

  "custom/input-method": {
    "exec": "$HOME/dotfiles/scripts/input-method-status.sh",
    "return-type": "json",
    "interval": 1,
    "on-click": "$HOME/dotfiles/scripts/input-method-status.sh --next"
  },

  "custom/hyprsunset": {
    "exec": "$HOME/dotfiles/scripts/hyprsunset-status.sh",
    "return-type": "json",
    "interval": 60
  },

  "mpris": {
    "format": "{status_icon} {dynamic}",
    "format-paused": "{status_icon}",
    "format-stopped": "",
    "dynamic-order": ["title", "artist"],
    "dynamic-len": 40,
    "title-len": 28,
    "artist-len": 18,
    "tooltip-format": "{title}\n{artist} â€” {album}",
    "status-icons": {
      "playing": "َ°گٹ",
      "paused": "َ°ڈ¤",
      "stopped": "َ°“›"
    }
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "َ°‌ں",
    "tooltip-format": "Volume: {volume}%\nOutput: {desc}",
    "format-icons": {
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "max-volume": 100,
    "scroll-step": 5,
    "on-click": "pavucontrol"
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip-format-activated": "Idle timeout: disabled",
    "tooltip-format-deactivated": "Idle timeout: enabled",
    "format-icons": {
      "activated": "َ°…¶",
      "deactivated": "َ°¾ھ"
    }
  },

  "custom/power": {
    "format": "َ°گ¥",
    "tooltip-format": "Power menu",
    "menu": "on-click",
    "menu-file": "$HOME/dotfiles/config/unix/config/waybar/power-menu.xml",
    "menu-actions": {
      "lock": "loginctl lock-session",
      "suspend": "systemctl suspend",
      "logout": "uwsm app -- hyprshutdown",
      "reboot": "uwsm app -- hyprshutdown --post-cmd 'systemctl reboot'",
      "poweroff": "uwsm app -- hyprshutdown --post-cmd 'systemctl poweroff'"
    }
  },

  "network": {
    "format": "{ifname}",
    "format-ethernet": "َ°ˆ€",
    "format-wifi": "{icon}",
    "format-disconnected": "َ°–ھ",
    "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
    "tooltip-format-wifi": "Network: {essid} آ· {signalStrength}%",
    "tooltip-format-ethernet": "Network: {ifname} آ· {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Network: disconnected",
    "on-click": "ghostty -e nmtui"
  }
}
