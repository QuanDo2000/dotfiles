#!/usr/bin/env bash
set -euo pipefail

# Global variables (used in sourced scripts)
export DRY=false
export QUIET=false
export FORCE=false
# Portable readlink -f (macOS lacks GNU readlink -f)
_resolve() {
  local f="$0"
  while [ -L "$f" ]; do
    local d; d="$(cd -P "$(dirname "$f")" && pwd)"
    f="$(readlink "$f")"; [[ "$f" != /* ]] && f="$d/$f"
  done
  echo "$(cd -P "$(dirname "$f")" && pwd)/$(basename "$f")"
}
DOTFILES_DIR="$(cd "$(dirname "$(_resolve)")" && pwd)"
export DOTFILES_DIR
REPO_URL="https://github.com/QuanDo2000/dotfiles.git"

SCRIPTS_DIR="$DOTFILES_DIR/scripts"

# Validate that DOTFILES_DIR actually contains the repo we need. We only
# check for the scripts/ directory — a git check would break valid installs
# where the repo is owned by a different UID (e.g. read-only bind mount in
# a container) because git refuses to operate on such directories.
if [[ ! -d "$SCRIPTS_DIR" ]]; then
  echo "Error: $SCRIPTS_DIR not found — $DOTFILES_DIR does not look like a dotfiles checkout." >&2
  echo "Remove it or set DOTFILES_DIR to a valid clone of $REPO_URL." >&2
  exit 1
fi

# Source all modules
source "$SCRIPTS_DIR/utils.sh"
source "$SCRIPTS_DIR/platform.sh"
source "$SCRIPTS_DIR/packages.sh"
source "$SCRIPTS_DIR/verify.sh"
source "$SCRIPTS_DIR/obsidian.sh"

function update_repo {
  info "Updating dotfiles repo..."
  if [[ "$DRY" == "false" ]]; then
    cd "$DOTFILES_DIR" || return
    git pull --rebase --autostash || fail "Failed to pull dotfiles repo"
  fi
  success "Finished updating repo"
}

function setup_dotfiles {
  info "Setting up dotfiles..."
  install_packages
  update_repo
  setup_obsidian_if_supported
  success "Done!"
}

function setup_obsidian_if_supported {
  if [[ "$(detect_platform)" != "arch" ]]; then
    info "Skipping Obsidian sync setup: not Arch Linux"
    return
  fi
  if ! command -v npm >/dev/null 2>&1; then
    info "Skipping Obsidian sync setup: npm not found"
    return
  fi
  if ! command -v systemctl >/dev/null 2>&1; then
    info "Skipping Obsidian sync setup: systemctl not found"
    return
  fi
  if ! systemctl --user show-environment >/dev/null 2>&1; then
    info "Skipping Obsidian sync setup: systemd user session unavailable"
    return
  fi
  setup_obsidian
}

function usage {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS] [COMMAND]

Commands:
  all         Run full setup (default)
  update      Update Nix-managed packages
  packages    Install system packages only
  obsidian    Set up Obsidian headless sync (Arch auto-runs during 'all' when ready)
  verify      Verify core symlinks
  doctor      Detect Home Manager file conflicts

Options:
  -d, --dry     Dry run (no changes made)
  -f, --force   Overwrite existing files without prompting
  -q, --quiet   Only show errors
  -h, --help    Show this help message
EOF
}

# Parse options
while [[ $# -gt 0 ]]; do
  case "$1" in
  -d | --dry)
    DRY=true
    shift
    ;;
  -f | --force)
    FORCE=true
    shift
    ;;
  -q | --quiet)
    QUIET=true
    shift
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  *)
    break
    ;;
  esac
done

# Run command
case "${1:-all}" in
all) setup_dotfiles ;;
update)
  update_packages
  ;;
packages)
  install_packages
  ;;
obsidian) setup_obsidian ;;
verify) verify ;;
doctor) doctor ;;
*)
  fail "Unknown command: $1"
  ;;
esac
